10 WIDTH 80,25:CONSOLE 0,25,0,1:COLOR 4:CLS
20 DIM NI$(84),NI(84)
30 GOSUB 40000
40 '
50 '
70 COLOR 5:INPUT "Address = $",I$:ADD=VAL("&H"+I$)
80 COLOR 4:PRINT RIGHT$("000"+HEX$(ADD),4);TAB(21);
90 LINE INPUT J$
100 IF J$="" GOTO 70
110 CT=INSTR(J$," "):IF CT=0 THEN I0$=J$:I1$="":GOTO 130
120 I0$=LEFT$(J$,CT-1)
121 I1$=MID$(J$,CT+1)
122 CT=INSTR(I1$," "):IF CT THEN J$=I1$:GOTO 121
130 J0$=I0$:J1$=I1$:ADD0=ADD
140 PAGE=0
145 '
146 '
150 CT=0
160 IF I0$=NI$(CT)     GOTO 1000 ELSE CT=CT+1:IF CT-40 GOTO 160
170 IF LEFT$(I0$,LEN(NI$(CT)))=NI$(CT) GOTO 2000 ELSE CT=CT+1:IF CT-52 GOTO 170
180 IF I0$=NI$(CT)     GOTO 3000
190 IF I0$="L"+NI$(CT) GOTO 4000 ELSE CT=CT+1:IF CT-69 GOTO 180
200 IF I0$=NI$(CT)     GOTO 5000 ELSE CT=CT+1:IF CT-73 GOTO 200
210 IF I0$=NI$(CT)     GOTO 6000 ELSE CT=CT+1:IF CT-77 GOTO 210
220 IF I0$=NI$(CT)     GOTO 7000 ELSE CT=CT+1:IF CT-85 GOTO 220
230 IF I0$="ORCC"      THEN OP(0)=&H1A:GOTO 8000
240 IF I0$="ANDCC"     THEN OP(0)=&H1C:GOTO 8000
250 IF I0$="CWAI"      THEN OP(0)=&H3C:GOTO 8000
260 IF I0$="EXG"       THEN OP(0)=&H1E:GOSUB 22000:GOTO 1500
270 IF I0$="TFR"       THEN OP(0)=&H1F:GOSUB 22000:GOTO 1500
280 IF I0$="SWI"       GOTO 9000
290 IF I0$="SWI2"      THEN PAGE=&H10:GOTO 9000
300 IF I0$="SWI3"      THEN PAGE=&H11:GOTO 9000
310 GOSUB 50000
320 '
330 '
340 '
1000 OP(0)=(NI(CT) MOD 100):PAGE=INT(NI(CT)/100)
1010 GOSUB 10000:ZZ=OP(0) AND 15
1020 IF (ZZ=7 OR ZZ=13 OR ZZ=15) AND HI=0 THEN GOSUB 50000
1025 IF (ZZ<3 OR (ZZ>3 AND ZZ<12)) AND HI=0 THEN COUNT=1:OP(1)=TPLO
1030 OP(0)=OP(0)+&H80+HI
1040 '
1050 '
1500 LOCATE 5,CSRLIN-1
1502 PRINT STRING$(75," ");
1504 LOCATE 5,CSRLIN-1
1510 IF PAGE THEN PRINT RIGHT$("0"+HEX$(PAGE),2);" ";:ADD=ADD+1
1520 FOR I=0 TO COUNT
1530 PRINT RIGHT$("0"+HEX$(OP(I)),2);" ";:ADD=ADD+1
1540 NEXT
1550 PRINT TAB(21);J0$;TAB(28);J1$:GOTO 80
1560 '
1570 '
2000 OP(0)=NI(CT)
2010 IF I0$<>NI$(CT) GOTO 2060
2020 GOSUB 10000
2030 IF HI=&H10 THEN HI=-&H40
2040 OP(0)=OP(0)+HI+&H40:GOTO 1500
2050 '
2060 IF CT=50 OR I1$<>"" THEN GOSUB 50000
2070 I$=RIGHT$(I0$,1):COUNT=0
2080 IF I$="A" THEN HI=0:GOTO 2040
2090 IF I$="B" THEN HI=&H10:GOTO 2040 ELSE GOSUB 50000
2100 '
2110 '
3000 OP(0)=&H21+CT-52
3010 IF CT=67 THEN OP(0)=&H20
3015 IF CT=68 THEN OP(0)=&H8D
3020 GOSUB 10000:IF HI<>&H30 THEN GOSUB 50000
3030 TP=TP-ADD-2:OP(1)=TP AND &HFF
3035 IF TP>32767 THEN TP=TP-65536!
3036 IF TP<-128 OR TP>127 THEN GOSUB 50000
3040 COUNT=1:GOTO 1500
3060 '
3070 '
4000 PAGE=&H10:OP(0)=&H21+CT-52:ZZ=4
4010 IF CT=67 THEN OP(0)=&H16:PAGE=0:ZZ=3
4015 IF CT=68 THEN OP(0)=&H17:PAGE=0:ZZ=3
4020 GOSUB 10000:IF HI<>&H30 THEN GOSUB 50000
4030 TP=TP-ADD-ZZ:OP(1)=INT(TP/256):OP(2)=TP AND &HFF
4040 COUNT=2:GOTO 1500
4050 '
4060 '
5000 OP(0)=&H30+CT-69:GOSUB 10000:IF HI<>&H20 THEN GOSUB 50000 ELSE 1500
6000 OP(0)=&H34+CT-73:GOSUB 21000:GOTO 1500
7000 OP(0)=NI(CT):COUNT=0:IF I1$<>"" THEN GOSUB 50000 ELSE 1500
8000 GOSUB 10000:COUNT=1:OP(1)=TPLO:IF HI<>0 THEN GOSUB 50000 ELSE 1500
9000 COUNT=0:OP(0)=&H3F:GOTO 1500
9010 '
9020 '
10000 HI=0:IF I1$="" GOTO 50000
10010 HED$=LEFT$(I1$,1)
10020 IF HED$="#" THEN 11000 ' イミディエイト
10030 IF HED$="[" THEN 12000 ' インダイレクト
10080 IF HED$="<" THEN 17000 ' ダイレクト
10090 CT=INSTR(I1$,",")
10100 IF CT<>0    THEN 18000 ' インデックス１
10110 '
10120 I$=I1$:GOSUB 20000:HI=&H30
10130 OP(1)=TPHI:OP(2)=TPLO:COUNT=2:RETURN
10140 '
10150 '
11000 I$=MID$(I1$,2):GOSUB 20000:HI=0
11010 OP(1)=TPHI:OP(2)=TPLO:COUNT=2:RETURN
11020 '
11030 '
12000 FG=1:I1$=MID$(I1$,2,LEN(I1$)-2)
12010 IF INSTR(I1$,",")=0 GOTO 12050
12020 GOSUB 18001
12030 OP(1)=OP(1) OR &H10:HI=&H20:RETURN
12040 '
12050 I$=I1$:GOSUB 20000
12060 OP(1)=&H9F:OP(2)=TPHI:OP(3)=TPLO:COUNT=3:HI=&H20:RETURN
12070 '
12080 '
13000 TP$=MID$(I1$,3,1):GOSUB 19000:OP(1)=OP(1) OR (R*32):COUNT=1:RETURN
13010 '
13020 '
16000 TP$=MID$(I1$,2)
16010 IF INSTR(TP$,"++") THEN R$=MID$(TP$,1,1):OP(1)=&H81:GOTO 16060
16020 IF INSTR(TP$,"--") THEN R$=MID$(TP$,3,1):OP(1)=&H83:GOTO 16060
16030 IF INSTR(TP$,"+")  THEN R$=MID$(TP$,1,1):OP(1)=&H80:GOTO 16090
16040 IF INSTR(TP$,"-")  THEN R$=MID$(TP$,2,1):OP(1)=&H82:GOTO 16090
16050 R$=TP$:OP(1)=&H84
16060 OP(1)=OP(1) OR ((INSTR("XYUS",R$)-1)*32)
16070 COUNT=1:RETURN
16080 '
16090 IF FG=1 GOTO 50000 ELSE 16060
16095 '
16096 '
17000 I$=MID$(I1$,2):GOSUB 20000:HI=&H10
17010 OP(1)=TPLO:COUNT=1:RETURN
17020 '
17030 '
18000 FG=0:HI=&H20
18001 HED$=LEFT$(I1$,1)
18002 IF HED$="A" THEN OP(1)=&H86:GOTO 13000 ' Ａreg Offset
18003 IF HED$="B" THEN OP(1)=&H85:GOTO 13000 ' Ｂreg Offset
18004 IF HED$="D" THEN OP(1)=&H8B:GOTO 13000 ' Ｄreg Offset
18005 IF HED$="," GOTO 16000 ' インデックス２
18006 I$=LEFT$(I1$,INSTR(I1$,",")-1):GOSUB 20000
18010 IF INSTR(I1$,"PCR") GOTO 18070
18020 TP$=MID$(I1$,INSTR(I1$,",")+1):GOSUB 19000
18025 IF FG=1 GOTO 18040
18030 IF TP<16  AND TP>-17  THEN OP(1)=(R*32) OR (TP AND &H1F):COUNT=1:RETURN
18040 IF TP<128 AND TP>-129 THEN OP(1)=&H88 OR (R*32):OP(2)=TPLO:COUNT=2:RETURN
18050 OP(1)=&H89 OR (R*32):OP(2)=INT(TP/256):OP(3)=TP AND &HFF:COUNT=3:RETURN
18060 '
18070 TP=TP-ADD-3:IF PAGE THEN TP=TP-1
18080 IF TP<128 AND TP>-129 THEN OP(1)=&H8C:OP(2)=TP AND &HFF:COUNT=2:RETURN
18090 TP=TP-1:OP(1)=&H8D:OP(2)=INT(TP/256):OP(3)=TP AND &HFF:COUNT=3:RETURN
18100 '
19000 R=INSTR("XYUS",TP$)-1:RETURN
19010 '
19020 '
20000 ' TP <- val(I$)
20005 IF LEFT$(I$,1)="-" AND INSTR(I$,"$") THEN SI=-1:I$=MID$(I$,2) ELSE SI=1
20010 IF LEFT$(I$,1)="$" THEN TP=VAL("&H"+MID$(I$,2))*SI:GOTO 20030
20020 TP=VAL(I$)
20030 IF TP>32767 THEN TP=TP-65536!
20040 TPHI=INT(TP/256):TPLO=TP AND &HFF:RETURN
20050 '
20060 '
21000 ' push / pull
21010 OP(1)=0
21020 CT=INSTR(I1$,",")
21030 IF CT THEN I$=LEFT$(I1$,CT-1):I1$=MID$(I1$,CT+1):GOSUB 21050:GOTO 21020
21040 I$=I1$:COUNT=1
21050 IF I$="D" THEN OP(1)=OP(1) OR 6:RETURN
21055 OP(1)=OP(1) OR 2^(INT(INSTR("CCA B DP X Y SUPC",I$)/2-.5))
21060 RETURN
21070 '
21080 '
22000 ' transfer / exchange
22010 CT=INSTR(I1$,",")
22020 I$=LEFT$(I1$,CT-1):GOSUB 22500:OP(1)=R*16
22030 I$=MID$(I1$,CT+1):GOSUB 22500:OP(1)=OP(1)+R:COUNT=1:RETURN
22040 '
22500 R=INT(INSTR("D X Y U S PC    A B CCDP",I$)/2):RETURN
22510 '
22520 '
40000 ' Initialize
40010 FOR I= 0 TO 51:READ NI$(I),NI(I):NEXT
40030 FOR I=52 TO 76:READ NI$(I):NEXT
40050 FOR I=77 TO 84:READ NI$(I),NI(I):NEXT:RETURN
